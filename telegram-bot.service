[Unit]
Description=Telegram Claude Bot
After=network.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/home/YOUR_USER/telegram-claude-bot
ExecStart=/home/YOUR_USER/telegram-claude-bot/.venv/bin/python bot.py
Restart=on-failure
RestartSec=5
Environment=PATH=/home/YOUR_USER/.local/bin:/usr/local/bin:/usr/bin:/bin

[Install]
WantedBy=multi-user.target
